        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of channels",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "channels": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Integration not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/connectors": {
      "get": {
        "summary": "List available connector types",
        "tags": [
          "Integrations"
        ],
        "responses": {
          "200": {
            "description": "Available connector types",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "connectors": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string"
                          },
                          "transportMode": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/webhook/{connectorType}/{integrationId}": {
      "post": {
        "summary": "Receive inbound webhook from a messaging platform",
        "description": "Generic webhook endpoint for all connectors. Verifies HMAC signature, parses the message, and enqueues for async processing.",
        "tags": [
          "Webhooks"
        ],
        "security": [],
        "parameters": [
          {
            "in": "path",
            "name": "connectorType",
            "required": true,
            "schema": {
              "type": "string"
            },
